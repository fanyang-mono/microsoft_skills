{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": ".github/hooks/continual-learning/scripts/load-session-start.sh",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/continual-learning/scripts/track-tool-use.sh",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": ".github/hooks/continual-learning/scripts/reflect-session-end.sh",
        "cwd": ".",
        "timeoutSec": 15
      }
    ]
  }
}
